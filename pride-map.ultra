---
type: geojson
options:
  attributionControl:
    customAttribution: '<a href=".">Ultra</a> | <a href="https://github.com/Lumikeiju/pride-map">Github</a>'
controls:
  - type: GeolocateControl
    options:
      positionOptions:
        enableHighAccuracy: true
      trackUserLocation: true
style:
  extends: https://styles.trailsta.sh/protomaps-grayscale.json
  layers:
    - type: symbol
      filter:
        - any
        - [ ==, [ get, lgbtq ], only ]
        - [ ==, [ get, lgbtq ], primary ]
        - [ ==, [ get, lgbtq ], welcome ]
      icon-image:
        - match
        - [get, lgbtq]
        - only
        - https://lumikeiju.dev/pride-map/icons/osmheart_lgbtq_horizontal_24px.png
        - primary
        - https://lumikeiju.dev/pride-map/icons/osmheart_lgbtq_slanted_24px.png
        - welcome
        - https://lumikeiju.dev/pride-map/icons/osmpin_lgbtq_slanted_24px.png
        - https://lumikeiju.dev/pride-map/icons/osmpin_lgbtq_horizontal_24px.png
      icon-allow-overlap: true
      icon-anchor: bottom
      text-field: '{name}'
      text-optional: true
      text-anchor: top
      text-size: 12
      text-color: black
      text-halo-width: 1.5
      text-halo-color: white
---
https://lumikeiju.dev/pride-map/data.geojson
